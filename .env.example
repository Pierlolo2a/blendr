# Serveur
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Securite
# En production, restreindre aux domaines autorises : https://blendr.example.com
# En developpement, * est acceptable
CORS_ORIGIN=*

# Limites
MAX_ROOMS=500
MAX_IMAGE_KB=500
MAX_TEXT_CHARS=150
MAX_CHAT_CHARS=200

# Notes sur la securite avancee
# - Trust proxy est active (niveau 1) pour recuperer les vraies IPs derriere Railway/Render/Fly.io
# - Rate limit connexions Socket.IO : 10 connexions/IP/minute
# - Rate limit creation rooms : 5 rooms/IP/heure
# - Protection burst chat : max 3 messages en 2 secondes
# - Timeout inactivite lobby : 30 minutes
# - Limite memoire : max 20 steps par chaine de jeu
